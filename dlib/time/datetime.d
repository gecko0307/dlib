module dlib.time.datetime;

/// Structure that holds date and time.
struct DateTime
{
    /// Number of seconds passed from the beginning of the minute.
    int seconds;
    
    /// Number of minutes passed from the beginning of the hour.
    int minutes;
    
    /// Number of hours passed from the beginning of the day.
    int hours;
    
    /// Gregorian day of the month.
    int day;
    
    /// Gregorian month.
    int month;
    
    /// Gregorian year.
    int year;
    
    /// Day of the week, beginning from 1.
    int dayInWeek;
    
    /// Day in the year.
    int dayInYear;
}

public import dlib.time.ctime;

/// Initializes the mutex for thread-safe queries.
void init() nothrow @nogc
{
    dlib.time.ctime.init();
}

/// Converts C timestamp to DateTime.
DateTime dateTimeFromTm(tm* timeInfo) pure nothrow @nogc
{
    if (timeInfo is null)
        return DateTime();
    
    DateTime dateTime = {
        seconds: timeInfo.tm_sec,
        minutes: timeInfo.tm_min,
        hours: timeInfo.tm_hour,
        day: timeInfo.tm_mday,
        month: timeInfo.tm_mon,
        year: 1900 + timeInfo.tm_year,
        dayInWeek: timeInfo.tm_wday,
        dayInYear: timeInfo.tm_yday
    };
    
    return dateTime;
}

/// Queries current date-time from the system, taking a timezone into account.
DateTime currentTimeLocal() nothrow @nogc
{
    time_t t = time(null);
    tm timeInfo;
    localtime_s(&t, &timeInfo);
    return dateTimeFromTm(&timeInfo);
}

/// Queries current Coordinated Universal Time from the system.
DateTime currentTimeUTC() nothrow @nogc
{
    time_t t = time(null);
    tm timeInfo;
    gmtime_s(&t, &timeInfo);
    return dateTimeFromTm(&timeInfo);
}
